				{
					"name": "Health check (Auth)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{auth_url}}/health",
							"host": [
								"{{auth_url}}"
							],
							"path": [
								"health"
							]
						},
						"description": "Verifica que el servicio de autenticación esté levantado y saludable."
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Gestión de Tareas (Servicio A)",
			"item": [
				{
					"name": "Listar Tareas",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{tasks_url}}/tasks",
							"host": [
								"{{tasks_url}}"
							],
							"path": [
								"tasks"
							]
						},
						"description": "Obtiene la lista completa de tareas registradas (requiere token JWT en cabecera)."
					},
					"response": []
				},
				{
					"name": "Health check (Tareas)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:3003/health",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "3003",
							"path": [
								"health"
							]
						},
						"description": "Verifica el estado de salud de ms-gestion-tarea."
					},
					"response": []
				}
			]
		},
