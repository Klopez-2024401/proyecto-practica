			"item": [
				{
					"name": "Registrar usuario",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"name\": \"Test User\",\n    \"surname\": \"Mongoose\",\n    \"email\": \"testuser@example.com\",\n    \"password\": \"Password123!\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{auth_url}}/auth/register",
							"host": [
								"{{auth_url}}"
							],
							"path": [
								"auth",
								"register"
							]
						},
						"description": "Crea una nueva cuenta de usuario en la base de datos MongoDB compartida."
					},
					"response": []
				},
				{
					"name": "Iniciar sesión (Login)",
					"request": {
						"method": "POST",
						"header": [],
